using UnityEngine;

public class WesternCombat : MonoBehaviour {
    public GameObject bulletPrefab;
    public Transform firePoint;
    public float fireRate = 0.5f;
    private float nextFireTime;

    void Update() {
        // Left click to shoot
        if (Input.GetButtonDown("Fire1") && Time.time >= nextFireTime) {
            Shoot();
            nextFireTime = Time.time + fireRate;
        }
    }

    void Shoot() {
        Instantiate(bulletPrefab, firePoint.position, firePoint.rotation);
        // Add recoil or sound effects here
    }
}
using UnityEngine;

public class HorseSystem : MonoBehaviour {
    public Transform mountPoint;
    public GameObject player;
    private bool isRiding = false;

    void Update() {
        if (Input.GetKeyDown(KeyCode.E)) { // Press E to mount/dismount
            if (!isRiding) Mount();
            else Dismount();
        }

        if (isRiding) {
            // Simple horse movement logic
            float move = Input.GetAxis("Vertical") * 10f * Time.deltaTime;
            float turn = Input.GetAxis("Horizontal") * 50f * Time.deltaTime;
            transform.Translate(0, 0, move);
            transform.Rotate(0, turn, 0);
        }
    }

    void Mount() {
        isRiding = true;
        player.transform.SetParent(mountPoint);
        player.transform.localPosition = Vector3.zero;
        player.GetComponent<CharacterController>().enabled = false;
    }

    void Dismount() {
        isRiding = false;
        player.transform.SetParent(null);
        player.GetComponent<CharacterController>().enabled = true;
    }
}
